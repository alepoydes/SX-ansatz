      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h1 id=\"torons-from-topovecansatz\">Torons from <code>topovec.ansatz</code></h1>\n<span class=\"paragraph\">This notebook builds toron-like structures directly with the current\ncoordinate-first <code>topovec.ansatz</code> API.</span>\n<span class=\"paragraph\">The construction is:</span>\n<ol>\n<li>build cone and anti-cone coordinate charts from shifted/rotated meridional coordinates,</li>\n<li>form cholesteric spirals in those charts,</li>\n<li>add explicit cut and surface masks in physical units,</li>\n<li>normalize on a <code>0.5 um</code> cubic lattice,</li>\n<li>materialize ansatz-based <code>S1</code>, <code>S2</code>, and <code>S3</code>,</li>\n<li>supplement them with <code>CF1</code> loop demos on a separate hopfion-style grid.</li>\n</ol>\n<span class=\"paragraph\">The explicit article formulas live in the separate notebook\n<code>notebooks/article_torons.py</code>.</span></span>"
          }
        }
      ],
      "console": []
    },
